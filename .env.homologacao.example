# =============================================================================
# VARIÁVEIS DE AMBIENTE — AMBIENTE DE HOMOLOGAÇÃO
# =============================================================================
# ATENÇÃO: Este é um arquivo de EXEMPLO. Nunca comitar chaves reais.
# Copie este arquivo como .env.homologacao e preencha com as chaves do
# projeto Supabase de homologação.
#
# NÃO use chaves do projeto de PRODUÇÃO aqui.
# =============================================================================

# Identifica visualmente o ambiente (exibe banner laranja no sistema)
NEXT_PUBLIC_APP_ENV=homologacao

# URL pública da Preview Deployment gerada pela Vercel
NEXT_PUBLIC_APP_URL=https://sistema-controle-v3-git-homologacao-SEUPROJETO.vercel.app

# ── Supabase (projeto de homologação — separado de produção) ──────────────────
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXXXXXXXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.CHAVE-ANONIMA-DE-HOMOLOGACAO
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.CHAVE-SERVICE-ROLE-DE-HOMOLOGACAO

# ── Stripe (sempre usar chaves de TESTE — nunca sk_live_ em homologação) ──────
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_PRICE_ID=price_XXXXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Planos pagos de Reforma Tributária (produto tax_reform_only) ──────────────
# Um Price ID de teste por plano no Stripe. Sem esses valores, o checkout
# desses planos retorna erro amigável, mas a ativação manual (admin) funciona.
STRIPE_PRICE_ID_RT_ESSENCIAL=price_XXXXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_PRICE_ID_RT_PROFISSIONAL=price_XXXXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_PRICE_ID_RT_ILIMITADO=price_XXXXXXXXXXXXXXXXXXXXXXXXXX

# Allowlist de e-mails da equipe Enfokus com acesso a /leads-reforma-tributaria
# e /admin-reforma-tributaria (CSV, mesmo mecanismo para as duas áreas).
LEADS_ADMIN_EMAILS=equipe@enfokus.com.br
